# Xentral MCP environment. Copy to .env and fill in your values.
# Never commit a real token. Never paste a token into a chat. The token is
# shown once at creation in Xentral and cannot be retrieved later.

# Full instance host including the scheme, no version segment.
# Example. https://acme.xentral.biz
XENTRAL_API_URL=

# Instead of the full URL you may set only the instance id. It expands to
# https://<id>.xentral.biz. Use one of XENTRAL_API_URL or XENTRAL_ID.
XENTRAL_ID=

# Personal Access Token created under Account settings, Developer Settings.
XENTRAL_TOKEN=

# Read only guard. 1 keeps the server read only. Phase A is read only regardless.
XENTRAL_MCP_READONLY=1

# Per request timeout in milliseconds. Default 30000.
XENTRAL_MCP_TIMEOUT_MS=

# Character cap for formatted tool output. Default 20000.
XENTRAL_MAX_RESPONSE_CHARS=

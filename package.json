{
  "name": "xentral-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Xentral ERP API. Read-only tools over a local stdio transport.",
  "type": "module",
  "bin": {
    "xentral-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "smoke": "tsx test/smoke.ts",
    "test": "npm run smoke && npm run test:unit && npm run test:protocol && npm run test:worker && npm run test:aggression",
    "test:unit": "tsx --test test/unit/*.test.ts",
    "test:aggression": "tsx test/aggression.ts",
    "test:protocol": "tsx test/protocol.ts",
    "test:worker": "tsx --test test/worker.test.ts",
    "test:stress": "tsx test/stress.ts",
    "test:sweep": "tsx test/sweep.ts",
    "test:hosted": "tsx test/hosted.ts",
    "test:live": "npm run live && npm run live:write && npm run test:sweep && npm run test:stress && npm run test:hosted",
    "live": "tsx test/live.ts",
    "live:write": "tsx test/live-write.ts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "xentral",
    "erp",
    "claude",
    "ai-agent",
    "dach"
  ],
  "author": "Mirza Iqbal",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/mjmirza/xentral-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/mjmirza/xentral-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mjmirza/xentral-mcp/issues"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.3",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
